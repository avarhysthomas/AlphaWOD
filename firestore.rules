rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function currentUserExists() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return currentUserExists() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isSgpt() {
      return currentUserExists() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "sgpt";
    }

    function hasPerformanceAccess() {
      return isAdmin() || isSgpt();
    }

    function affectsOnly(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    function isReactionUpdate() {
      return affectsOnly(["reactionUserIds", "reactionUsers", "reactionCount"]);
    }

    function isCommentUpdate() {
      return affectsOnly(["comments", "commentCount"]);
    }

    function isWaiverUpdate() {
      return affectsOnly([
        "waiverAcceptedAt",
        "waiverAcceptedBy",
        "waiverAcceptedEmail",
        "waiverAcceptedName",
        "waiverAcceptedVersion",
        "waiverAcknowledgements",
        "waiverMediaConsent"
      ]);
    }

    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isOwnUser(userId);

      allow update: if isAdmin() || (
        isOwnUser(userId) &&
        (
          isWaiverUpdate() ||
          (
            request.resource.data.role == resource.data.role &&
            request.resource.data.approvalStatus == resource.data.approvalStatus &&
            request.resource.data.strengthBlock == resource.data.strengthBlock
          )
        )
      );

      allow delete: if false;

      match /trainingLogs/{logId} {
        allow read: if isOwnUser(userId) || hasPerformanceAccess();
        allow write: if isOwnUser(userId) || isAdmin();
      }
    }

    match /{path=**}/trainingLogs/{logId} {
      allow read: if hasPerformanceAccess() || (
        isSignedIn() &&
        resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn() &&
        (
          request.resource.data.userId == request.auth.uid ||
          isAdmin()
        );
      allow update, delete: if isAdmin() || (
        isSignedIn() &&
        resource.data.userId == request.auth.uid
      );
    }

    match /workoutSessions/{workoutId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
    }

    match /feedPosts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.actorId == request.auth.uid;
      allow update: if isAdmin() || (
        isSignedIn() &&
        (
          resource.data.actorId == request.auth.uid ||
          isReactionUpdate() ||
          isCommentUpdate()
        )
      );
      allow delete: if isAdmin() || (
        isSignedIn() &&
        resource.data.actorId == request.auth.uid
      );
    }

    match /movementLibrary/{movementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /wods/{wodDate} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() &&
        affectsOnly(["bookedCount"])
      );
    }

    match /bookings/{bookingId} {
      allow read: if isAdmin() || (
        isSignedIn() &&
        (
          !exists(/databases/$(database)/documents/bookings/$(bookingId)) ||
          resource.data.userId == request.auth.uid ||
          bookingId.matches(".*_" + request.auth.uid)
        )
      );

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.classId == resource.data.classId
      );

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
